<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.masterescala.comunidad-vip</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__INSTALL_DIR__/pipeline_diario.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__INSTALL_DIR__</string>

    <!-- Corre cada 10 minutos (600 segundos) — clasifica contactos modificados
         de forma cuasi-tiempo-real sin necesidad de webhook/tunnel. -->
    <key>StartInterval</key>
    <integer>600</integer>

    <!-- También dispara una vez al cargar la rutina, así arranca inmediato. -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Si el Mac está apagado/dormido cuando le tocaría correr, ejecuta
         tan pronto despierte (no se acumulan). -->
    <key>StartOnMount</key>
    <false/>

    <key>StandardOutPath</key>
    <string>__INSTALL_DIR__/logs/launchd.out.log</string>

    <key>StandardErrorPath</key>
    <string>__INSTALL_DIR__/logs/launchd.err.log</string>

    <!-- Variables de entorno mínimas -->
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
