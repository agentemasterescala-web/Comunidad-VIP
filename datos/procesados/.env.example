# Credenciales GHL para la API. Copiar a .env y completar.
# .env NUNCA debe subirse a git (está en .gitignore).
#
# El token se genera en GHL: Settings → Integrations → Private Integration Tokens
# El location ID se ve en la URL: app.gohighlevel.com/v2/location/<LOCATION_ID>/...

GHL_TOKEN=pit-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
GHL_LOCATION=xxxxxxxxxxxxxxxxxxxx

# --- Envío de correos desde el dashboard (servidor_local.py) ---
# Para que el botón "Enviar a N seleccionados" funcione, necesitas
# un App Password de Google (16 caracteres, sin espacios o con espacios da igual).
# Cómo crearlo:
#   1. myaccount.google.com → Seguridad
#   2. Activa la Verificación en 2 pasos (si no está)
#   3. "Contraseñas de aplicaciones" → genera una
# El correo FROM debe ser de tu dominio Workspace.
# Pega el resultado abajo:

GMAIL_FROM=tu-correo@tudominio.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_FROM_NAME=Iván Caicedo  # opcional, nombre visible
PORT_LOCAL=8888                # opcional, puerto del servidor local
